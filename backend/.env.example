# Backend Environment Variables
# Copy ke .env dan isi dengan value lo

PORT=3001
FRONTEND_URL=https://domainlo.com

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lofi_dashboard
DB_USER=postgres
DB_PASS=ganti_dengan_password_lo

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Secret bersama antara n8n dan backend
# Generate dengan: openssl rand -hex 32
INTERNAL_API_KEY=ganti_dengan_secret_random_lo

# Path ke folder lagu di VPS
SONGS_DIR=/opt/songs
