# Media Pool Server — Environment Variables
# Copy ke .env dan sesuaikan

# Port server ini (default 3002)
MEDIA_POOL_PORT=3002

# Folder root tempat media disimpan di VPS
# Struktur: /opt/media/music/[kategori]/file.mp3
#            /opt/media/video/[kategori]/file.mp4
MEDIA_BASE_DIR=/opt/media

# rclone remote untuk sync ke Google Drive
# Format: nama_remote:nama_folder_di_drive
RCLONE_REMOTE=gdrive:media-pool

# Set ke false kalau rclone belum disetup / development lokal
RCLONE_ENABLED=true
